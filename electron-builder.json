{
  "$schema": "https://raw.githubusercontent.com/electron-userland/electron-builder/master/packages/app-builder-lib/scheme.json",
  "appId": "com.devlilic.punctulpeazi.graphics",
  "asar": true,
  "productName": "Punctul pe Azi",
  "directories": {
    "output": "release/${version}"
  },
  "publish": [
    {
      "provider": "github",
      "owner": "devLilic",
      "repo": "CsvEditor-PA",
      "releaseType": "release"
    }
  ],
  "files": [
    "dist-electron",
    "dist"
  ],
  "mac": {
    "artifactName": "PunctulPeAzi-Graphics-${version}-${os}.${ext}",
    "target": [
      "dmg"
    ]
  },
  "win": {
    "icon": "build/icons/icon.ico",
    "target": [
      {
        "target": "nsis",
        "arch": [
          "x64"
        ]
      }
    ],
    "artifactName": "PunctulPeAzi-Graphics-${version}-${os}.${ext}"
  },
  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowToChangeInstallationDirectory": true,
    "deleteAppDataOnUninstall": false
  },
  "linux": {
    "target": ["AppImage"],
    "artifactName": "PunctulPeAzi-Graphics-${version}-${os}.${ext}"
  }
}
